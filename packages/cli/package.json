{
  "name": "@cloudcart/cli",
  "version": "0.3.3",
  "description": "CloudCart Developer CLI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cloudcart": "./bin/cloudcart.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "pnpm build && oclif manifest"
  },
  "dependencies": {
    "@cloudcart/app": "workspace:*",
    "@cloudcart/cli-kit": "workspace:*",
    "@cloudcart/nitro-plugin": "workspace:*",
    "@oclif/core": "^4.2.8",
    "@oclif/plugin-help": "^6.2.27",
    "@oclif/plugin-version": "^2.2.24",
    "@oclif/plugin-warn-if-update-available": "^3.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "oclif": "^4.17.7",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "oclif": {
    "bin": "cloudcart",
    "dirname": "cloudcart",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-version",
      "@oclif/plugin-warn-if-update-available",
      "@cloudcart/app",
      "@cloudcart/nitro-plugin"
    ],
    "topicSeparator": " ",
    "warn-if-update-available": {
      "timeoutInDays": 7,
      "message": "<%= config.name %> update available: <%= chalk.greenBright(config.version) %> \u2192 <%= chalk.greenBright(latest) %>.\nRun <%= chalk.cyan('npm i -g @cloudcart/cli@latest') %> to update."
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudcart/cli.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
