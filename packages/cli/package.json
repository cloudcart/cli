{
  "name": "@cloudcart/cli",
  "version": "0.1.0",
  "description": "CloudCart Developer CLI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cloudcart": "./bin/cloudcart.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["bin", "dist", "oclif.manifest.json"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "pnpm build && oclif manifest"
  },
  "dependencies": {
    "@cloudcart/app": "workspace:*",
    "@cloudcart/cli-kit": "workspace:*",
    "@oclif/core": "^4.2.8",
    "@oclif/plugin-help": "^6.2.27",
    "@oclif/plugin-version": "^2.2.24"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "oclif": "^4.17.7",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "oclif": {
    "bin": "cloudcart",
    "dirname": "cloudcart",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-version",
      "@cloudcart/app"
    ],
    "topicSeparator": " "
  },
  "engines": { "node": ">=20.0.0" }
}
